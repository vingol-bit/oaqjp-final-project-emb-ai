"""
This script implements a server that detects detectable sentiments in a text.
"""
# Import the Flask class from the flask module --->flask --app server --debug run
from flask import Flask, make_response, request, render_template
from EmotionDetection.emotion_detection import emotion_detector

# Create an instance
#
# of the Flask class, passing in the name of the current module
app = Flask(__name__)

@app.route("/")
def render_index_page():
    """
    Defines a function called render_index_page, which responds
    to the application path root '/'.
    The index.html template is rendered
    """
    return render_template('index.html')

@app.route("/emotionDetector")
def sent_emotion():
    """
    Sends the text to be examined to the analysis detector module,
    formats the string in vase to the value returned by the detector and 
    returns it to the caller
    """
    text = request.args.get('textToAnalyze')
    emotions = emotion_detector(text)
    resp = None
    if emotions['dominant_emotion'] is None:
        resp = "Invalid text! Please try again!."
    else:
        resp = (
            f"For the given statement, the system response is 'anger':"
            f" {emotions['anger']}, 'disgust': {emotions['disgust']}, 'fear':"
            f" {emotions['fear']}, 'joy': {emotions['joy']} and 'sadness':"
            f" {emotions['sadness']}. The dominant emotion is"
            f" {emotions['dominant_emotion']}."
        )
    return make_response(resp)

if __name__ == '__main__':
    app.run(port=5000)
